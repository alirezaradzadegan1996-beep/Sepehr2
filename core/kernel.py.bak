from core.intent import detect_intent
from core.cortex.system_bus import bus
from core.cortex.cortex import cortex


class Kernel:

    def __init__(
        self,
        memory,
        planner,
        skill_engine,
        context_memory=None
    ):

        print("[Kernel] System Started")

        self.memory = memory
        self.planner = planner
        self.skill_engine = skill_engine
        self.context_memory = context_memory

        self.cortex = cortex
        self.router = None

        try:
            self.router = self.cortex.get("router")
        except Exception:
            pass


    def start(self):

        print("[Kernel] Ready")
        bus.publish(
            "kernel.started"
        )


    def process(self, user_input):

        # -------------------------
        # Clean Input
        # -------------------------

        user_input = user_input.replace(
            "[Kernel] Received:",
            ""
        )

        user_input = user_input.replace(
            "kernel received",
            ""
        )

        user_input = user_input.replace(
            "علیرضا:",
            ""
        )

        user_input = user_input.strip()


# -------------------------
# Active Project Workflow
# -------------------------

try:
    from core.project_manager import _pm

    active = _pm.get_active()

    workflow_commands = [
        "بعدی",
        "ادامه",
        "ادامه پروژه",
        "مرحله بعد",
        "next",
        "continue",
    ]

    if active and user_input.lower() in workflow_commands:
        print("[PROJECT] Continue Workflow")

        result = _pm.continue_project()

        if isinstance(result, dict):
            return result.get("message", str(result))

        return result

except Exception as e:
    print("[PROJECT WORKFLOW]", e)

print(
    "\n[Kernel] Received:",
    user_input
)


        bus.publish(
            "kernel.input",
            user_input
        )


        # -------------------------
        # Decision Engine
        # -------------------------

        decision = self.cortex.decide(
            user_input
        )


        print(
            "[DECISION]",
            decision.decision.decision_type,
            decision.decision.confidence
        )


        decision_type = decision.decision.decision_type


        intent = decision_type


        # -------------------------
        # Exit
        # -------------------------

        if user_input in [
            "خروج",
            "exit",
            "quit"
        ]:

            return "خداحافظ ❤️"


        # -------------------------
        # Dispatcher
        # -------------------------

        try:

            print("\n===== SERVICES =====")
            print(self.cortex.services())
            print("====================")

            dispatcher = self.cortex.get(
                "dispatcher"
            )

            print("[SERVICE]", decision.decision.service)

            result = dispatcher.dispatch(
                decision.decision.service,
                user_input
            )


            if result is not None:

                if isinstance(result, dict):

                    return result.get(
                        "message",
                        str(result)
                    )

                return result


        except Exception as e:

            print(
                "[DISPATCH ERROR]",
                e
            )


        # -------------------------
        # Intent
        # -------------------------

        print(
            "[INTENT]",
            intent
        )


        bus.publish(
            "intent.detected",
            intent
        )


        # -------------------------
        # Project System
        # -------------------------

        if intent == "project":


            if user_input == "بعدی":

                result = self.memory.next_project_step()

                if result is None:

                    project = (
                        self.memory
                        .get_active_project()
                    )

                    if project and project.get(
                        "status"
                    ) == "completed":

                        return (
                            "🚀 پروژه کامل شد.\n\n"
                            f"📌 نام پروژه:\n"
                            f"{project.get('goal')}\n\n"
                            "✅ تحویل پروژه انجام شد."
                        )


                    return "❌ مرحله بعدی وجود ندارد."


                if isinstance(result, dict):

                    return result.get(
                        "message",
                        str(result)
                    )


                return result


            plan = self.planner.create_plan(
                user_input,
                intent
            )


            result = self.skill_engine.execute(
                plan
            )


            if isinstance(result, dict):

                return result.get(
                    "message",
                    str(result)
                )


            return result



        # -------------------------
        # Router
        # -------------------------

        if self.router:

            try:

                answer = self.router.handle(
                    user_input
                )

                if answer:

                    return answer


            except Exception as e:

                print(
                    "[CORTEX ROUTER ERROR]",
                    e
                )


        # -------------------------
        # Default Skill
        # -------------------------

        plan = self.planner.create_plan(
            user_input,
            intent
        )


        result = self.skill_engine.execute(
            plan
        )


        if isinstance(result, dict):

            return result.get(
                "message",
                str(result)
            )


        bus.publish(
            "kernel.response",
            result
        )


        return result
